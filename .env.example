# Evolution API Configuration
EVOLUTION_SERVER_URL=https://seu-servidor-evolution.com
EVOLUTION_API_KEY=COLE_SUA_CHAVE
EVOLUTION_INSTANCE=nome_da_instancia
EVOLUTION_GROUP_ID=120000000000000000@g.us

# Meta Marketing API Configuration
META_ACCESS_TOKEN=COLE_SEU_TOKEN
META_BUSINESS_ID=000000000000000

# Runtime
MAX_RETRIES=3
RETRY_DELAY_SECONDS=300
TZ=America/Sao_Paulo
META_BALANCE_IS_CENTS=true

# Thresholds padrao para CRON (opcional)
ALERT_THRESHOLD=200
NEAR_THRESHOLD=120

# Opcional: arquivo JSON com contas monitoradas
# Formato padrao: config/meta_ad_accounts.json
META_ACCOUNTS_JSON_PATH=config/meta_ad_accounts.json

# Opcional legado: monitorar apenas contas especificas
# IDs separados por virgula
META_ALLOWED_ACCOUNT_IDS=
# Formato: id=Nome amigavel;id=Nome amigavel
META_ACCOUNT_LABELS=
