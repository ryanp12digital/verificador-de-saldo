# Evolution API Configuration
EVOLUTION_SERVER_URL=https://seu-servidor-evolution.com
EVOLUTION_API_KEY=COLE_SUA_CHAVE
EVOLUTION_INSTANCE=nome_da_instancia
EVOLUTION_GROUP_ID=120000000000000000@g.us

# Meta Marketing API Configuration
META_ACCESS_TOKEN=COLE_SEU_TOKEN
META_BUSINESS_ID=000000000000000

# Runtime
MAX_RETRIES=3
RETRY_DELAY_SECONDS=300
TZ=America/Sao_Paulo
META_BALANCE_IS_CENTS=true

# Thresholds padrao para CRON (opcional)
ALERT_THRESHOLD=200
NEAR_THRESHOLD=120

# Opcional: arquivo JSON com contas monitoradas (usado se Postgres NAO estiver configurado)
META_ACCOUNTS_JSON_PATH=config/meta_ad_accounts.json

# Opcional legado: monitorar apenas contas especificas (sem Postgres)
META_ALLOWED_ACCOUNT_IDS=
META_ACCOUNT_LABELS=

# --- PostgreSQL (opcional). Se definido, lista de contas vem do banco (strict). ---
# Opcao A: URI completa
# DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Opcao B: variaveis separadas
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=usuario
POSTGRES_PASSWORD=senha
POSTGRES_DB=verificador_saldo
# POSTGRES_SSLMODE=require

# --- Dashboard web (opcional) ---
DASHBOARD_API_TOKEN=defina_um_token_longo_e_secreto
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=5050

# No Docker, para subir a dashboard junto do CRON:
# DASHBOARD_ENABLED=true
# DASHBOARD_HOST=0.0.0.0

# --- Google Ads (opcional; monitor + saldos na dashboard) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# Conta manager (MCC) se consultar contas de clientes:
# GOOGLE_ADS_LOGIN_CUSTOMER_ID=1234567890

# JSON fallback se nao usar Postgres:
GOOGLE_ACCOUNTS_JSON_PATH=config/google_ad_accounts.json
